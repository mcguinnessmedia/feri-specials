---
import '../styles/app.css';

interface Props {
  title?: string;
}

const { title = 'Hope Market Specials' } = Astro.props;
---

<!doctype html>
<html
  lang='en'
  data-theme='light'
>
  <head>
    <meta charset='UTF-8' />
    <meta
      name='viewport'
      content='width=device-width, initial-scale=1.0'
    />
    <title>{title}</title>
  </head>
  <body class='bg-base-100 text-base-content'>
    <slot />
  </body>
</html>
